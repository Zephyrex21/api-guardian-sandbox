PORT=3000

# From your GitHub App's settings page (github.com/settings/apps/<your-app>)
GITHUB_APP_ID=

# Paste the full contents of the .pem file GitHub gives you when you click
# "Generate a private key". Keep the literal "\n" sequences if you're
# pasting it as a single line into a platform env var (Render, Vercel) -
# src/config.js converts them back to real newlines automatically.
GITHUB_APP_PRIVATE_KEY=

# Set this to whatever secret string you enter in the GitHub App's
# "Webhook secret" field - it must match exactly on both sides.
GITHUB_WEBHOOK_SECRET=

# Required - MongoDB Atlas free tier connection string. Create a free
# cluster at mongodb.com/cloud/atlas, then get the connection string from
# "Connect" -> "Drivers". It looks like:
# mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/api-guardian
MONGODB_URI=

# Used to build the acknowledgment link in PR comments. Leave this blank
# for local testing - it defaults to http://localhost:3000, and you can
# copy the link out of a PR comment and open it in your own browser on
# this same machine to test it. Set it to your real Render URL (e.g.
# https://api-guardian.onrender.com) once deployed, so the link works for
# anyone who clicks it, not just you on your own machine.
PUBLIC_URL=

# Required for login (Phase 5). Get these from the SAME GitHub App you
# already created: github.com/settings/apps/<your-app> -> the Client ID is
# shown near the top of the page. For the secret, scroll to "Client
# secrets" and click "Generate a new client secret" (different from the
# private key .pem file you generated in Phase 0 - this is a separate
# credential specifically for OAuth login).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Any long random string - signs the login session cookie. Generate one
# the same way you generated the webhook secret.
SESSION_SECRET=

# The dashboard frontend's URL - needed for CORS and cookies to work
# across the two domains once deployed. Leave blank for local dev (it
# defaults to http://localhost:5173, matching Vite's default port). Set to
# your real Vercel URL once the frontend is deployed.
FRONTEND_URL=

# Optional - the app works fully without this, it just won't post to
# Slack. Create an Incoming Webhook: go to api.slack.com/apps, "Create New
# App" -> "From scratch", name it (e.g. "API Guardian"), pick your
# workspace. In the app's settings, go to "Incoming Webhooks", toggle it
# on, click "Add New Webhook to Workspace", choose the channel, copy the
# URL it gives you (starts with https://hooks.slack.com/services/...).
SLACK_WEBHOOK_URL=

# Optional - the app works fine without these (falls back to the raw diff
# list, no plain-English explanations). Get a free Groq key at
# console.groq.com/keys. Get a free Gemini key at aistudio.google.com/apikey.
# Only Groq is required to see the AI layer in action; Gemini is a fallback
# if Groq is ever down or rate-limited.
GROQ_API_KEY=
GEMINI_API_KEY=
